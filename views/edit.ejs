<%- include('partials/header', { pageTitle: 'Edit Post' }) %>

<!-- MASTHEAD (slim) -->
<header class="masthead" style="padding: 1rem 1.5rem 0.75rem;">
  <h1 class="masthead__title" style="font-size: clamp(1.5rem, 4vw, 2.5rem);">Insight<span>Verse</span></h1>
</header>

<nav class="navbar">
  <a href="/posts/<%= post.id %>" class="nav-filter">← Back to Post</a>
  <div class="nav-spacer"></div>
  <span style="font-family: var(--sans); font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase;">Editing Post</span>
</nav>

<main>
  <div class="form-page">
    <h2 class="form-page__title">Edit Post</h2>
    <p class="form-page__sub">Revise, refine, and republish.</p>

    <form action="/posts/<%= post.id %>/update" method="POST">
      <div class="form-group">
        <label for="title">Post Title</label>
        <input
          type="text"
          id="title"
          name="title"
          class="form-input"
          value="<%= post.title %>"
          required
          maxlength="120"
        />
      </div>

      <div class="form-group">
        <label for="category">Category</label>
        <select name="category" id="category" class="form-select" required>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= post.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="content">Content</label>
        <textarea
          id="content"
          name="content"
          class="form-textarea"
          required
        ><%= post.content %></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes →</button>
        <a href="/posts/<%= post.id %>" class="btn btn-outline">Cancel</a>
        <form action="/posts/<%= post.id %>/delete" method="POST" style="margin-left: auto;" onsubmit="return confirm('Delete this post?')">
          <button type="submit" class="btn btn-danger">Delete Post</button>
        </form>
      </div>
    </form>
  </div>
</main>

<%- include('partials/footer') %>
