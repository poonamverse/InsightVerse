<%- include('partials/header', { pageTitle: 'New Post' }) %>

<!-- MASTHEAD (slim) -->
<header class="masthead" style="padding: 1rem 1.5rem 0.75rem;">
  <h1 class="masthead__title" style="font-size: clamp(1.5rem, 4vw, 2.5rem);">Insight<span>Verse</span></h1>
</header>

<nav class="navbar">
  <a href="/" class="nav-filter">← Back</a>
  <div class="nav-spacer"></div>
  <span style="font-family: var(--sans); font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase;">New Post</span>
</nav>

<main>
  <div class="form-page">
    <h2 class="form-page__title">Write Something New</h2>
    <p class="form-page__sub">Share a perspective on movies, sports, psychology, or anything that matters.</p>

    <form action="/posts" method="POST">
      <div class="form-group">
        <label for="title">Post Title</label>
        <input
          type="text"
          id="title"
          name="title"
          class="form-input"
          placeholder="A compelling headline…"
          required
          maxlength="120"
        />
      </div>

      <div class="form-group">
        <label for="category">Category</label>
        <select name="category" id="category" class="form-select" required>
          <option value="" disabled selected>Select a category</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>"><%= cat %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="content">Content</label>
        <textarea
          id="content"
          name="content"
          class="form-textarea"
          placeholder="Write your post here. Each paragraph should be on its own line…"
          required
        ></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Publish Post →</button>
        <a href="/" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>
</main>

<%- include('partials/footer') %>
